# ── SZINN.ai Environment Variables ──────────────────────────────────────────
# Kopieer dit bestand naar .env voor lokale ontwikkeling (server.js gebruikt dit niet direct,
# maar Netlify Dev leest .env automatisch in).

# JWT signing secret — VERPLICHT in productie, verander dit!
JWT_SECRET=szinn-jwt-verander-mij-2026

# Admin wachtwoord voor het beheer-paneel (/admin)
ADMIN_PASSWORD=szinn-admin

# Anthropic API key — optioneel, alleen nodig voor AI Companion chat
# ANTHROPIC_API_KEY=sk-ant-...

# Netlify Blobs context — wordt automatisch ingevuld door Netlify in productie.
# Bij gebruik van `netlify dev` lokaal is dit ook automatisch beschikbaar.
# NETLIFY_BLOBS_CONTEXT=...
